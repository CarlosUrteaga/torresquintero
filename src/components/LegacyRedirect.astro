---
interface Props {
  to: string;
}

const { to } = Astro.props;
const target = new URL(to.replace(/^\//, ""), new URL(import.meta.env.BASE_URL, Astro.site));
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <meta name="robots" content="noindex" />
    <title>Redireccionando | Torres Quintero</title>
  </head>
  <body>
    <p>La página cambió de dirección. <a href={target}>Continuar al contenido</a>.</p>
  </body>
</html>
