---
import { navigation, site, whatsappUrl } from "../data/site";

const pathname = Astro.url.pathname;
---
<header class="site-header">
  <div class="topbar">
    <div class="container topbar-inner">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <span>Informes: {site.whatsappDisplay}</span>
    </div>
  </div>
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label={`${site.name}, inicio`}>
      <span class="brand-mark">
        <img src="/images/escudo-primaria.jpg" alt="Escudo de Primaria Profr. Gregorio Torres Quintero" />
      </span>
      <span><strong>Colegio</strong> Torres Quintero</span>
    </a>
    <nav class="desktop-nav" aria-label="Navegación principal">
      {navigation.map((item) => (
        <a class:list={{ active: pathname === item.href }} href={item.href}>{item.label}</a>
      ))}
      <a class="nav-cta" href={whatsappUrl} target="_blank" rel="noreferrer">Pedir informes</a>
    </nav>
    <details class="mobile-menu">
      <summary aria-label="Abrir menú de navegación">
        <span>Explorar</span>
        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="m5 7.5 5 5 5-5"></path>
        </svg>
      </summary>
      <nav aria-label="Navegación móvil">
        {navigation.map((item) => (
          <a class:list={{ active: pathname === item.href }} href={item.href}>{item.label}</a>
        ))}
        <a class="nav-cta" href={whatsappUrl} target="_blank" rel="noreferrer">Pedir informes</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header { position: sticky; z-index: 20; top: 0; background: rgb(255 255 255 / 96%); box-shadow: 0 4px 20px rgb(18 38 74 / 8%); backdrop-filter: blur(12px); }
  .topbar { padding: .35rem 0; color: white; background: var(--navy); font-size: .78rem; }
  .topbar-inner { display: flex; flex-wrap: wrap; justify-content: space-between; gap: .4rem 1rem; }
  .topbar a { text-decoration: none; }
  .nav-wrap { position: relative; display: flex; min-height: 76px; align-items: center; justify-content: space-between; gap: 1rem; }
  .brand { display: flex; align-items: center; gap: .7rem; color: var(--navy); font-size: .92rem; line-height: 1.1; text-decoration: none; }
  .brand strong { display: block; font-family: Georgia, "Times New Roman", serif; font-size: 1.1rem; }
  .brand-mark {
    width: 48px;
    height: 56px;
    flex: 0 0 auto;
    overflow: hidden;
    background: var(--blue);
    clip-path: polygon(50% 0, 94% 15%, 94% 51%, 86% 68%, 72% 83%, 50% 100%, 28% 83%, 14% 68%, 6% 51%, 6% 15%);
  }
  .brand-mark img { width: 100%; height: 100%; object-fit: cover; }
  .mobile-menu { position: relative; }
  summary {
    display: flex;
    min-height: 44px;
    cursor: pointer;
    align-items: center;
    gap: .4rem;
    padding: .65rem 1rem;
    border-radius: 999px;
    background: var(--yellow);
    color: var(--navy);
    font-weight: 700;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  summary svg { width: 18px; fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 2; transition: transform .2s ease; }
  .mobile-menu[open] summary svg { transform: rotate(180deg); }
  nav a { color: var(--navy); font-weight: 600; text-decoration: none; }
  nav a:hover, nav a.active { color: var(--blue); }
  .nav-cta { border-radius: 999px; background: var(--yellow); text-align: center; }
  .desktop-nav { display: none; }
  .mobile-menu nav {
    position: absolute;
    top: calc(100% + .8rem);
    right: 0;
    display: grid;
    width: min(340px, calc(100vw - 2rem));
    padding: 1rem;
    border: 1px solid #e5e9ef;
    border-radius: 1rem;
    background: white;
    box-shadow: var(--shadow);
  }
  .mobile-menu nav a { padding: .7rem; }
  .mobile-menu nav a:hover, .mobile-menu nav a.active { border-radius: .6rem; background: var(--sky); }
  @media (min-width: 480px) and (max-width: 699px) {
    .mobile-menu {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    .mobile-menu nav {
      right: auto;
      left: 50%;
      transform: translateX(-50%);
    }
  }
  @media (min-width: 700px) {
    .nav-wrap { flex-wrap: wrap; padding-block: .7rem; }
    .brand { flex: 1 0 100%; }
    .mobile-menu { display: none; }
    .desktop-nav {
      display: flex;
      width: 100%;
      align-items: center;
      justify-content: space-between;
      gap: .1rem;
      padding-top: .55rem;
      border-top: 1px solid #edf0f4;
    }
    .desktop-nav a { padding: .45rem .4rem; font-size: clamp(.7rem, 1.25vw, .86rem); white-space: nowrap; }
    .desktop-nav a:hover, .desktop-nav a.active { border-radius: .55rem; background: var(--sky); }
    .desktop-nav .nav-cta { margin-left: .35rem; padding-inline: .8rem; }
  }
  @media (min-width: 1180px) {
    .nav-wrap { flex-wrap: nowrap; padding-block: 0; }
    .brand { flex: 0 0 auto; }
    .desktop-nav { width: auto; gap: .15rem; padding-top: 0; border-top: 0; }
    .desktop-nav a { padding: .55rem .48rem; font-size: .84rem; }
  }
</style>
