---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
---
<BaseLayout title="Jardín de Niños" description="Jardín de Niños del Colegio Torres Quintero.">
  <section class="page-hero"><div class="container"><span class="eyebrow">Jardín de niños</span><h1>La comunidad es primero.</h1><p class="lead">Actividades curriculares y extracurriculares que permiten crear vínculos con la comunidad y acompañar los primeros aprendizajes.</p></div></section>
  <section class="section"><div class="container split"><div class="split-media"><img src="/images/aprendizaje-preescolar.jpg" alt="Estudiante de Jardín de Niños trabajando con letras" /></div><div><span class="eyebrow">Aprender y participar</span><h2>Una experiencia activa</h2><p>En el Colegio Profr. Gregorio Torres Quintero ofrecemos opciones para que nuestros alumnos se involucren directamente en las actividades y construyan su camino de aprendizaje.</p><p>El modelo educativo considera la etapa de desarrollo de cada niña y niño para favorecer un aprendizaje integral, significativo y con valores.</p><a class="button button-dark" href="/modelo-educativo/">Ver modelo educativo</a></div></div></section>
  <section class="section section-soft"><div class="container"><span class="eyebrow">Espacios</span><h2>Jardín de Niños en imágenes</h2><div class="grid-3"><img class="level-photo" src="/images/patio-preescolar.jpg" alt="Patio de Jardín de Niños" /><img class="level-photo" src="/images/preescolar-aula.jpg" alt="Aula de Jardín de Niños" /><img class="level-photo" src="/images/comunidad-preescolar.jpg" alt="Actividad de Jardín de Niños" /></div></div></section>
  <Cta title="Solicita información sobre Jardín de Niños." />
</BaseLayout>
<style>.level-photo{width:100%;height:330px;object-fit:cover;border-radius:var(--radius)}</style>
