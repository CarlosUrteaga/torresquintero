---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
---
<BaseLayout title="Niveles educativos" description="Jardín de Niños y Primaria en el Colegio Torres Quintero.">
  <section class="page-hero"><div class="container"><span class="eyebrow">Niveles educativos</span><h1>Acompañamiento para cada etapa.</h1><p class="lead">Nuestra comunidad ofrece Jardín de Niños y Primaria con actividades curriculares y extracurriculares.</p></div></section>
  <section class="section"><div class="container grid-2"><article class="card"><img src="images/aprendizaje-preescolar.jpg" alt="Estudiante de Jardín de Niños" /><div class="card-body"><span class="eyebrow">Jardín de niños</span><h2>Primeros aprendizajes</h2><p>Una experiencia que permite a los alumnos involucrarse, convivir y construir su propio camino de aprendizaje.</p><a class="button button-dark" href="preescolar/">Conocer Preescolar</a></div></article><article class="card"><img src="images/comunidad-preescolar.jpg" alt="Actividad escolar acompañada" /><div class="card-body"><span class="eyebrow">Primaria</span><h2>Desarrollo integral</h2><p>Participación, análisis, colaboración y valores para fortalecer aprendizajes significativos.</p><a class="button button-dark" href="primaria/">Conocer Primaria</a></div></article></div></section>
  <Cta />
</BaseLayout>
