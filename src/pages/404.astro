---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Página no encontrada" description="La página solicitada no está disponible.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Error 404</span>
      <h1>Esta página no está disponible.</h1>
      <p class="lead">Puedes volver al inicio o comunicarte con el colegio para recibir información.</p>
      <a class="button button-dark" href="">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
