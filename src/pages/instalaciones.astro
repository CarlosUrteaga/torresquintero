---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import { gallery } from "../data/site";
---
<BaseLayout title="Instalaciones" description="Aulas, patios y espacios del Colegio Torres Quintero.">
  <section class="page-hero"><div class="container"><span class="eyebrow">Instalaciones</span><h1>Espacios de nuestra comunidad educativa.</h1><p class="lead">Un recorrido visual por las aulas, patios y áreas que forman parte de la vida escolar.</p></div></section>
  <section class="section"><div class="container gallery">{gallery.slice(0, 9).map((photo) => <img src={photo.src} alt={photo.alt} loading="lazy" />)}</div></section>
  <Cta title="Agenda una visita y conoce el colegio." />
</BaseLayout>
