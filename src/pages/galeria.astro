---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import { getAlbumCover, getAlbums, photoPath } from "../data/albums";

const albums = getAlbums();
---
<BaseLayout title="Galería" description="Galería de actividades e instalaciones de Torres Quintero.">
  <section class="page-hero"><div class="container"><span class="eyebrow">Galería</span><h1>Momentos de la vida escolar.</h1><p class="lead">Imágenes del archivo del Colegio Profr. Gregorio Torres Quintero.</p></div></section>
  <section class="section">
    <div class="container album-grid">
      {albums.map((album) => {
        const cover = getAlbumCover(album);
        return (
          <a class="album-card" href={`/galeria/${album.slug}/`}>
            <img src={photoPath(album, cover)} alt={cover.alt} loading="lazy" />
            <div>
              <p class="eyebrow">{album.photos.length} fotos</p>
              <h2>{album.title}</h2>
              <p>{album.description}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
  <Cta />
</BaseLayout>

<style>
  .album-grid { display: grid; gap: 1.4rem; }
  .album-card {
    display: grid;
    overflow: hidden;
    border: 1px solid #e5e9ef;
    border-radius: var(--radius);
    background: white;
    box-shadow: var(--shadow);
    color: inherit;
    text-decoration: none;
  }
  .album-card img { width: 100%; height: 330px; object-fit: cover; }
  .album-card div { padding: 1.5rem; }
  .album-card h2 { margin-bottom: .6rem; font-size: clamp(1.7rem, 3vw, 2.4rem); }
  @media (min-width: 760px) {
    .album-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
