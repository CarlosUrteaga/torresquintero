---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cta from "../components/Cta.astro";
import { activities } from "../data/site";
---
<BaseLayout title="Primaria" description="Primaria del Colegio Torres Quintero.">
  <section class="page-hero"><div class="container"><span class="eyebrow">Primaria</span><h1>Aprendizaje significativo y formación en valores.</h1><p class="lead">Una experiencia escolar que favorece la participación, el análisis, la colaboración y los vínculos con la comunidad.</p></div></section>
  <section class="section"><div class="container split"><div><span class="eyebrow">Participación activa</span><h2>Estudiantes protagonistas de su aprendizaje</h2><p>Nuestra primaria trabaja desde una corriente constructivista. Los alumnos construyen conocimientos a partir de su entorno y se involucran activamente con los contenidos y materiales.</p><p>Las actividades buscan favorecer el pensamiento crítico y una comprensión profunda, acompañando el desarrollo integral de cada estudiante.</p><a class="button button-dark" href="admisiones/">Revisar admisiones</a></div><div class="split-media"><img src="images/primaria-aula.jpg" alt="Aula de primaria del Colegio Torres Quintero" /></div></div></section>
  <section class="section section-soft"><div class="container"><span class="eyebrow">Formación complementaria</span><h2>Actividades de Primaria</h2><div class="grid-3">{activities.map((activity) => <article class="card"><div class="card-body"><h3>{activity.title}</h3><p>{activity.text}</p></div></article>)}</div></div></section>
  <Cta title="Solicita información sobre Primaria." />
</BaseLayout>
