---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.name,
  description = site.description,
  image = "images/vida-escolar.jpg",
} = Astro.props;
const fullTitle = title === site.name ? title : `${title} | ${site.shortName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const basePath = `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}`;
const baseUrl = new URL(basePath, Astro.site);
const socialImage = new URL(image, baseUrl);
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <base href={baseUrl.toString()} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#12264a" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
